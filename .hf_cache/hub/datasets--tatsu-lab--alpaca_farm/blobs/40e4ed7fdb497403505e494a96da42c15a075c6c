"""Utils for hosting Alpaca data on spaces."""

import json

import datasets

_CITATION = """
@misc{alpaca_farm,
  author = {Yann Dubois, Xuechen Li, Rohan Taori, Tianyi Zhang, Ishaan Gulrajani, Jimmy Ba, Carlos Guestrin, Percy Liang, Tatsunori Hashimoto},
  title = {AlpacaFarm: A Simulation Framework for Methods that Learn from Human Feedback},
  year = {2023},
  howpublished = {\\url{https://github.com/tatsu-lab/alpaca_farm}},
}
"""

# You can copy an official description
_DESCRIPTION = """
Data used in the original AlpacaFarm experiments.
Includes SFT and preference examples.
"""

_HOMEPAGE = "https://huggingface.co/datasets/tatsu-lab/alpaca_farm"

_LICENSE = "CC BY 4.0"

# The HuggingFace Datasets library doesn't host the datasets but only points to the original files.
# This can be an arbitrary nested dict/list of URLs (see below in `_split_generators` method)
_URLS = {
    "alpaca_instructions": {
        "preference": "./alpaca_instructions/preference.json",
        "sft": "./alpaca_instructions/sft.json",
        "unlabeled": "./alpaca_instructions/unlabeled.json",
        "val": "./alpaca_instructions/val.json",
    },
    "alpaca_farm_evaluation": "./alpaca_farm_evaluation.json",
    "alpaca_human_preference": "./alpaca_human_preference.json",
    "alpaca_gpt4_preference": "./alpaca_gpt4_preference.json",
    "alpaca_noisy_multi_preference": "./alpaca_noisy_multi_preference.json",
}


class AlpacaFarmDataset(datasets.GeneratorBasedBuilder):
    VERSION = datasets.Version("1.0.0")

    BUILDER_CONFIGS = [
        datasets.BuilderConfig(
            name="alpaca_instructions", version=VERSION, description="Alpaca 52K with split information."
        ),
        datasets.BuilderConfig(
            name="alpaca_farm_evaluation", version=VERSION, description="Official AlpacaFarm evaluation set."
        ),
        datasets.BuilderConfig(
            name="alpaca_human_preference",
            version=VERSION,
            description="Alpaca human preference collected on 10k PREF split.",
        ),
        datasets.BuilderConfig(
            name="alpaca_gpt4_preference",
            version=VERSION,
            description="Alpaca default GPT-4 preference collected on 10k PREF + 10k extra split.",
        ),
        datasets.BuilderConfig(
            name="alpaca_noisy_multi_preference",
            version=VERSION,
            description="Alpaca noisy multi auto-annotator preference collected on 10k PREF split.",
        ),
    ]

    DEFAULT_CONFIG_NAME = "alpaca_instructions"

    def _info(self):
        if self.config.name == "alpaca_instructions":
            features = datasets.Features(
                {
                    "instruction": datasets.Value("string"),
                    "input": datasets.Value("string"),
                    "output": datasets.Value("string"),
                }
            )
        elif self.config.name == "alpaca_farm_evaluation":
            features = datasets.Features(
                {
                    "instruction": datasets.Value("string"),
                    "input": datasets.Value("string"),
                    "output": datasets.Value("string"),
                    "generator": datasets.Value("string"),
                    "sample_mode": datasets.Value("string"),
                    "dataset": datasets.Value("string"),
                    "datasplit": datasets.Value("string"),
                }
            )
        elif self.config.name in ("alpaca_gpt4_preference", "alpaca_noisy_multi_preference"):
            features = datasets.Features(
                {
                    "instruction": datasets.Value("string"),
                    "input": datasets.Value("string"),
                    "output_1": datasets.Value("string"),
                    "output_2": datasets.Value("string"),
                    "preference": datasets.Value("int64"),
                }
            )
        elif self.config.name in ("alpaca_human_preference",):
            features = datasets.Features(
                {
                    "instruction": datasets.Value("string"),
                    "input": datasets.Value("string"),
                    "output_1": datasets.Value("string"),
                    "output_2": datasets.Value("string"),
                    "preference": datasets.Value("int64"),
                    "raw_preference": datasets.Value("int64"),
                }
            )
        else:
            raise NotImplementedError()

        return datasets.DatasetInfo(
            description=_DESCRIPTION,
            features=features,
            homepage=_HOMEPAGE,
            license=_LICENSE,
            citation=_CITATION,
        )

    def _split_generators(self, dl_manager):
        urls = _URLS[self.config.name]
        data_dir = dl_manager.download_and_extract(urls)
        print(data_dir)
        if self.config.name == "alpaca_instructions":
            return [
                datasets.SplitGenerator(
                    name=split,
                    gen_kwargs={
                        "filepath": data_dir[split],
                        "split": split,
                    },
                )
                for split in ["sft", "preference", "unlabeled", "val"]
            ]
        elif self.config.name == "alpaca_farm_evaluation":
            return [
                datasets.SplitGenerator(
                    name="eval",
                    gen_kwargs={
                        "filepath": data_dir,
                        "split": "eval",
                    },
                )
            ]
        elif self.config.name in ("alpaca_human_preference", "alpaca_gpt4_preference", "alpaca_noisy_multi_preference"):
            return [
                datasets.SplitGenerator(
                    name="preference",
                    gen_kwargs={
                        "filepath": data_dir,
                        "split": "preference",
                    },
                )
            ]

    def _generate_examples(self, filepath, split):
        with open(filepath, encoding="utf-8") as f:
            data = json.load(f)

        for key, example in enumerate(data):
            if self.config.name in (
                "alpaca_instructions",
                "alpaca_human_preference",
                "alpaca_gpt4_preference",
                "alpaca_farm_evaluation",
                "alpaca_noisy_multi_preference",
            ):
                # Yields examples as (key, example) tuples
                yield key, example
            else:
                raise NotImplementedError()
